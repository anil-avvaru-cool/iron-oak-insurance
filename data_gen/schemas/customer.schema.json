{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aioi.internal/schemas/customer.schema.json",
  "title": "AIOI Customer Record",
  "type": "object",
  "required": ["customer_id", "first_name", "last_name", "state", "zip", "dob", "created_at", "source"],
  "additionalProperties": false,
  "properties": {
    "customer_id":  { "type": "string", "pattern": "^CUST-[0-9]{5,6}$" },
    "first_name":   { "type": "string", "minLength": 1 },
    "last_name":    { "type": "string", "minLength": 1 },
    "state":        { "type": "string", "minLength": 2, "maxLength": 2 },
    "zip":          { "type": "string", "pattern": "^[0-9]{5}$" },
    "email":        { "type": ["string", "null"] },
    "dob":          { "type": "string", "format": "date" },
    "credit_score": { "type": ["integer", "null"], "minimum": 300, "maximum": 850 },
    "created_at":   { "type": "string" },
    "source":       { "type": "string", "const": "synthetic-v1" }
  }
}
