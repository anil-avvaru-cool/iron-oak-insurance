{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aioi.internal/schemas/iso_claim_history.schema.json",
  "title": "AIOI ISO Claim History Record",
  "type": "object",
  "required": ["iso_id", "customer_id", "vin", "prior_carrier", "prior_claim_date", "prior_claim_type", "prior_claim_amount", "role", "fraud_indicator", "source"],
  "additionalProperties": false,
  "properties": {
    "iso_id":              { "type": "string", "pattern": "^ISO-[0-9]{6}$" },
    "customer_id":         { "type": "string", "pattern": "^CUST-[0-9]{5,6}$" },
    "vin":                 { "type": "string", "minLength": 17, "maxLength": 17 },
    "prior_carrier":       { "type": "string", "enum": ["StateFarm","Allstate","Progressive","Geico","Farmers","USAA","Travelers","Liberty"] },
    "prior_claim_date":    { "type": "string", "format": "date" },
    "prior_claim_type":    { "type": "string", "enum": ["collision","comprehensive","liability","pip","uninsured_motorist"] },
    "prior_claim_amount":  { "type": "number", "minimum": 0 },
    "role":                { "type": "string", "enum": ["claimant","witness","third_party"] },
    "fraud_indicator":     { "type": "boolean" },
    "source":              { "type": "string", "const": "synthetic-iso-v1" }
  }
}